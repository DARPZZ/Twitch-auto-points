{
  "name": "Twitch-auto-points",
  "description": "This extension is made for Twitch auto claiming channel points",
  "version": "1.0.1",
  "manifest_version": 2,

  "permissions": [
    "activeTab",
    "https://www.twitch.tv/*",
    "http://*/*",
    "https://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"]
    }
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "@extension-twitch-auto-points-collection",
      "update_url": "https://darpzz.github.io/Twitch-auto-points/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
